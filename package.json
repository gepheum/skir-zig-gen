{
  "name": "skir-zig-gen",
  "version": "0.1.4",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "Tyler Fibonacci <gepheum@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "format-skir": "cd e2e-test && skir format && cd ..",
    "format-skir:check": "cd e2e-test && skir format --ci && cd ..",
    "format:zig": "cd e2e-test && zig fmt $(find src -name '*.zig' -not -path '*/skirout/*') && cd ..",
    "format:zig:check": "cd e2e-test && zig fmt --check $(find src -name '*.zig' -not -path '*/skirout/*') && cd ..",
    "format": "prettier --write \"**/*.ts\" && npm run format-skir && npm run format:zig",
    "format:check": "prettier --check \"**/*.ts\" && npm run format-skir:check && npm run format:zig:check",
    "test": "npm run build && cd e2e-test && skir gen && zig build && cd ..",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "skir-internal": "^0.2.19",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.6.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "prettier": "^3.2.4",
    "prettier-plugin-organize-imports": "^4.2.0",
    "skir": "^1.1.22",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.56.0"
  },
  "overrides": {
    "diff": "^8.0.3",
    "minimatch": "^10.2.2",
    "serialize-javascript": "^7.0.4"
  }
}
